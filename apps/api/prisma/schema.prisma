generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role     @default(user)
  createdAt DateTime @default(now())

  cases     Case[]   @relation("UserCases")
  audits    AuditEvent[]
}

model Case {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("UserCases", fields: [ownerId], references: [id])
}

model AuditEvent {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
}